    <external-path
        name="external_files"
        path="." />
    
    <!-- Application specific external storage -->
    <external-files-path
        name="external_app_files"
        path="." />
    
    <!-- Application specific external cache -->
    <external-cache-path
        name="external_app_cache"
        path="." />
    
    <!-- Internal files directory -->
    <files-path
        name="internal_files"
        path="." />
    
    <!-- Internal cache directory -->
    <cache-path
        name="internal_cache"
        path="." />
    
    <!-- Configuration exports directory -->
    <files-path
