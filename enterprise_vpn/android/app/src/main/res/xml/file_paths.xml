        path="exports/" />
    
    <!-- Logs directory -->
    <files-path
        name="logs"
        path="logs/" />
    
    <!-- Certificates directory -->
    <files-path
        name="certificates"
        path="certs/" />
    
    <!-- Downloads directory -->
    <external-path
        name="downloads"
        path="Download/" />
