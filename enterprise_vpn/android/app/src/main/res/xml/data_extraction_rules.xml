<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="." />
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="sharedpref" path="vpn_credentials.xml" />
        <exclude domain="sharedpref" path="auth_tokens.xml" />
        <exclude domain="database" path="vpn_cache.db" />
        <exclude domain="file" path="cache/" />
        <exclude domain="file" path="logs/" />
        <exclude domain="file" path="temp/" />
        <exclude domain="no_backup" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="user_preferences.xml" />
        <include domain="sharedpref" path="app_settings.xml" />
        <exclude domain="sharedpref" path="secure_prefs.xml" />
        <exclude domain="sharedpref" path="vpn_credentials.xml" />
        <exclude domain="database" path="." />
        <exclude domain="file" path="." />
        <exclude domain="no_backup" path="." />
    </device-transfer>
</data-extraction-rules>
